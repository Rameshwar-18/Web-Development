<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Whatsapp</title>
</head>
<body>
    <h3>All chats</h3>

    <% for(let chat of chats){ %>
        <div>
            <p>From: <%= chat.from %></p>
            <p><%= chat.message %></p>
            <p>Received by <%= chat.to %></p>
        </div>
    <% } %>

</body>
</html>